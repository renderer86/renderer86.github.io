---
layout: page
---

<script src="{{ site.baseurl | prepend: site.url }}/assets/js/blogs.js"></script>

<div class="home">
  <div id="categories">
    <div>
      <div class="blog-page">
        <div class="item-filter">
          <div class="item-filter-title">FILTERS</div>

          <div class="blog-filter-big">
            <input type="checkbox" id="computergraphics" checked /><label for="computergraphics"></label><span class="blog-filter-big-title">Computer Graphics</span><span id="computergraphics_chevron" class="chevron"></span>
          </div>
          <div id="computergraphics_subtech">
            <div class="blog-filter-small"><input type="checkbox" id="rendering" checked /><label for="rendering"></label><span class="blog-filter-small-title">Rendering</span></div>
            <div class="blog-filter-small"><input type="checkbox" id="graphicsprogramming" checked /><label for="graphicsprogramming"></label><span class="blog-filter-small-title">Graphics Programming</span></div>
            <div class="blog-filter-small"><input type="checkbox" id="raytracing" checked /><label for="raytracing"></label><span class="blog-filter-small-title">Ray Tracing</span></div>
            <div class="blog-filter-small"><input type="checkbox" id="shadow" checked /><label for="shadow"></label><span class="blog-filter-small-title">Shadow</span></div>
            <div class="blog-filter-small"><input type="checkbox" id="lighting" checked /><label for="lighting"></label><span class="blog-filter-small-title">Lighting</span></div>
            <div class="blog-filter-small"><input type="checkbox" id="geometry" checked /><label for="geometry"></label><span class="blog-filter-small-title">Geometry</span></div>
          </div>

          <div class="blog-filter-big">
            <input type="checkbox" id="unrealengine" checked /><label for="unrealengine"></label><span class="blog-filter-big-title">Unreal Engine</span><span id="unrealengine_chevron" class="chevron"></span>
          </div>
          <div id="unrealengine_subtech">
            <div class="blog-filter-small"><input type="checkbox" id="nanite" checked /><label for="nanite"></label><span class="blog-filter-small-title">Nanite</span></div>
            <div class="blog-filter-small"><input type="checkbox" id="virtualshadowmap" checked /><label for="virtualshadowmap"></label><span class="blog-filter-small-title">Virtual Shadow Map</span></div>
            <div class="blog-filter-small"><input type="checkbox" id="megalights" checked /><label for="megalights"></label><span class="blog-filter-small-title">MegaLights</span></div>
            <div class="blog-filter-small"><input type="checkbox" id="distancefield" checked /><label for="distancefield"></label><span class="blog-filter-small-title">Distance Field</span></div>
            <div class="blog-filter-small"><input type="checkbox" id="lumen" checked /><label for="lumen"></label><span class="blog-filter-small-title">Lumen</span></div>
          </div>

          <div class="blog-filter-big">
            <input type="checkbox" id="tools" checked /><label for="tools"></label><span class="blog-filter-big-title">Tools & AI</span><span id="tools_chevron" class="chevron"></span>
          </div>
          <div id="tools_subtech">
            <div class="blog-filter-small"><input type="checkbox" id="mcp" checked /><label for="mcp"></label><span class="blog-filter-small-title">MCP</span></div>
            <div class="blog-filter-small"><input type="checkbox" id="ai" checked /><label for="ai"></label><span class="blog-filter-small-title">AI</span></div>
            <div class="blog-filter-small"><input type="checkbox" id="llm" checked /><label for="llm"></label><span class="blog-filter-small-title">LLM</span></div>
            <div class="blog-filter-small"><input type="checkbox" id="automation" checked /><label for="automation"></label><span class="blog-filter-small-title">Automation</span></div>
          </div>

          <div class="blog-filter-big">
            <input type="checkbox" id="game" checked /><label for="game"></label><span class="blog-filter-big-title">Game</span><span id="game_chevron" class="chevron"></span>
          </div>
          <div id="game_subtech">
            <div class="blog-filter-small"><input type="checkbox" id="gamedesign" checked /><label for="gamedesign"></label><span class="blog-filter-small-title">Game Design</span></div>
            <div class="blog-filter-small"><input type="checkbox" id="essay" checked /><label for="essay"></label><span class="blog-filter-small-title">Essay</span></div>
          </div>
        </div>

        <div class="items">
          {% assign posts = site.posts | sort: "index" | reverse %}
          {% for post in posts %}
            {% if post.show %}
              <div class="blog-post-item {% if post.tags.size > 0 %}{% for tag in post.tags %}{{ tag }} {% endfor %}{% endif %}">
                <a href="{{ post.url | relative_url }}" class="category-post-link">
                  <h3>
                    {{ post.title }}
                    {% if post.new == true %}
                      <span class="category-item-new"></span>
                    {% endif %}
                  </h3>
                  {% if site.excerpt or site.theme_settings.excerpt %}
                    <div class="excerpt">
                      {% if site.excerpt == "truncate" %}
                        {{ post.content | strip_html | truncate: '250' | escape }}
                      {% else %}
                        {{ post.excerpt | strip_html | truncate: '75' | escape }}
                      {% endif %}
                    </div>
                  {% endif %}
                </a>
                {% if post.tags.size > 0 %}
                  <div class='tag-list'>
                    {% for tag in post.tags %}
                      <a class='button' href='{{site.baseurl}}/tags/#{{ tag }}'>{{ tag }}</a>
                    {% endfor %}
                  </div>
                {% endif %}
              {% assign _author2 = post.author2 %}
              {% include blog/post_info.liquid author=post.author author2=_author2 date=post.date %}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>
